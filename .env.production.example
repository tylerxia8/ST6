DATABASE_URL=jdbc:postgresql://st6-postgres.example.us-east-1.rds.amazonaws.com:5432/st6
DATABASE_USERNAME=st6_app
DATABASE_PASSWORD=replace-with-secret-manager-value

SPRING_PROFILES_ACTIVE=prod
AUTH0_ISSUER_URI=https://your-tenant.us.auth0.com/
ST6_CORS_ALLOWED_ORIGINS=https://pa.example.com,https://st6-assets.example.com

VITE_API_MODE=api
VITE_API_BASE_URL=https://api.example.com/api

AWS_REGION=us-east-1
ST6_WEB_BUCKET=st6-web-assets
ST6_CLOUDFRONT_DISTRIBUTION_ID=replace-with-distribution-id

ST6_API_IMAGE=ghcr.io/tylerxia8/st6-api:replace-with-tag
ST6_WEB_IMAGE=ghcr.io/tylerxia8/st6-web:replace-with-tag
